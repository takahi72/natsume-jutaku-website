---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { SITE } from '../lib/site';
---

<BaseLayout
  title="アクセス"
  description={`${SITE.name}への所在地・アクセス方法をご案内します。`}
  breadcrumbs={[
    { name: 'トップ', path: '/' },
    { name: 'アクセス', path: '/access/' },
  ]}
>
  <header class="page-header">
    <div class="container">
      <SectionHeading eyebrow="Access" title="アクセス" as="h1" />
    </div>
  </header>

  <section class="section">
    <div class="container access-grid">
      <div>
        <h2>所在地</h2>
        <p>
          〒{SITE.postalCode}<br />
          {SITE.prefecture}{SITE.city}{SITE.addressRest}
        </p>
        <h2>電話番号</h2>
        <p><a href={SITE.telHref}>{SITE.tel}</a></p>
        <h2>営業時間</h2>
        <p>
          {SITE.businessHours}<br />
          定休日: {SITE.closedDays}
        </p>
      </div>
      <MapEmbed />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-lg);
  }

  .access-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .access-grid h2 {
    font-size: var(--fs-md);
    margin-top: var(--space-md);
  }

  .access-grid h2:first-child {
    margin-top: 0;
  }

  @media (min-width: 768px) {
    .access-grid {
      grid-template-columns: 1fr 1.2fr;
      align-items: start;
    }
  }
</style>
