---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CardGrid from '../components/CardGrid.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { SITE } from '../lib/site';

const testimonials = (await getCollection('testimonials')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="お客様の声"
  description={`${SITE.name}で家づくりをされたお客様の声をご紹介します。`}
  breadcrumbs={[
    { name: 'トップ', path: '/' },
    { name: 'お客様の声', path: '/voice/' },
  ]}
>
  <header class="page-header">
    <div class="container">
      <SectionHeading eyebrow="Voice" title="お客様の声" as="h1" lead="家づくりを終えられたお客様からいただいた声です。" />
    </div>
  </header>

  <section class="section">
    <div class="container">
      <CardGrid minColumnWidth="320px">
        {testimonials.map((entry) => <TestimonialCard entry={entry} />)}
      </CardGrid>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-lg);
  }
</style>
