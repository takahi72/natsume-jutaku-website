---
import { SITE } from '../lib/site';

const query = encodeURIComponent(`${SITE.prefecture}${SITE.city}${SITE.addressRest}`);
const mapSrc = SITE.mapEmbedSrc || `https://maps.google.com/maps?q=${query}&z=15&output=embed`;
---

<div class="map-embed">
  <iframe
    src={mapSrc}
    title={`${SITE.name}の地図`}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

<style>
  .map-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .map-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
