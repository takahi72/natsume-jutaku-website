---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
  as?: 'h1' | 'h2' | 'h3';
}

const { eyebrow, title, lead, align = 'left', as: Tag = 'h2' } = Astro.props;
---

<div class={`section-heading section-heading--${align}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <Tag>{title}</Tag>
  {lead && <p class="lead">{lead}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--space-lg);
  }

  .section-heading--center {
    text-align: center;
  }

  .section-heading--center .lead {
    margin-inline: auto;
  }
</style>
