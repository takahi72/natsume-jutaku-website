---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'testimonials'>;
}

const { entry } = Astro.props;
const { customerName, projectTitle, quote } = entry.data;
---

<figure class="testimonial-card">
  <svg class="testimonial-card__quote" viewBox="0 0 32 24" aria-hidden="true" focusable="false">
    <path
      fill="currentColor"
      d="M0 24V13.5Q0 6.6 3.5 3.3T13 0v5.4Q9.3 6 7.65 8.1T6 13h6v11H0Zm19 0V13.5q0-6.9 3.5-10.2T32 0v5.4q-3.7.6-5.35 2.7T25 13h6v11H19Z"
    />
  </svg>
  <blockquote>
    <p>{quote}</p>
  </blockquote>
  <figcaption>
    <span class="testimonial-card__name">{customerName}</span>
    {projectTitle && <span class="testimonial-card__project">{projectTitle}</span>}
  </figcaption>
</figure>

<style>
  .testimonial-card {
    margin: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .testimonial-card__quote {
    width: 32px;
    height: 24px;
    color: var(--color-accent-soft);
  }

  .testimonial-card blockquote {
    margin: 0;
    font-size: var(--fs-md);
    line-height: var(--leading-body);
  }

  .testimonial-card figcaption {
    display: flex;
    flex-direction: column;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .testimonial-card__name {
    font-weight: 700;
    color: var(--color-text);
  }
</style>
