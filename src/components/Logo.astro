---
import { SITE, withBase } from '../lib/site';
---

<a href={withBase('/')} class="logo" aria-label={`${SITE.name} トップページ`}>
  <svg class="logo__mark" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
    <path
      d="M4 22 L20 8 L36 22"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
    <path
      d="M9 19 V33 H31 V19"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
    <line x1="20" y1="24" x2="20" y2="33" stroke="currentColor" stroke-width="2.5"></line>
  </svg>
  <span class="logo__text">
    <span class="logo__ja">{SITE.name}</span>
    <span class="logo__en">{SITE.nameEn}</span>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    color: var(--color-text);
  }

  .logo__mark {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo__ja {
    font-family: var(--font-serif);
    font-size: var(--fs-md);
    letter-spacing: 0.06em;
  }

  .logo__en {
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .logo__en {
      display: none;
    }
  }
</style>
