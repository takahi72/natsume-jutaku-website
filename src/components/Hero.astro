---
import { withBase } from '../lib/site';

interface Cta {
  href: string;
  label: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  primaryCta: Cta;
  secondaryCta: Cta;
}

const { eyebrow, title, lead, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero">
  <div class="hero__art" aria-hidden="true">
    <svg viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
      <g fill="none" stroke="currentColor" stroke-width="1.4" opacity="0.5">
        <path d="M40 320 L300 120 L560 320" />
        <path d="M100 300 V520 H500 V300" />
        <line x1="300" y1="380" x2="300" y2="520" />
        <line x1="180" y1="380" x2="260" y2="380" />
        <line x1="180" y1="420" x2="260" y2="420" />
        <line x1="340" y1="380" x2="420" y2="380" />
        <line x1="340" y1="420" x2="420" y2="420" />
      </g>
      <g fill="none" stroke="currentColor" stroke-width="1" opacity="0.25">
        <circle cx="300" cy="300" r="260" />
        <circle cx="300" cy="300" r="200" />
      </g>
    </svg>
  </div>

  <div class="container hero__inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="hero__title">
      {title.split('\n').map((line, i, lines) => (
        <>
          {line}
          {i < lines.length - 1 && <br />}
        </>
      ))}
    </h1>
    <p class="lead hero__lead">{lead}</p>
    <div class="hero__actions">
      <a href={withBase(primaryCta.href)} class="btn btn--primary">{primaryCta.label}</a>
      <a href={withBase(secondaryCta.href)} class="btn btn--outline">{secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-2xl) var(--space-xl);
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
  }

  .hero__art {
    position: absolute;
    top: 50%;
    right: -10%;
    width: min(640px, 60vw);
    aspect-ratio: 1 / 1;
    transform: translateY(-50%);
    color: var(--color-accent);
    opacity: 0.5;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    max-width: 640px;
  }

  .hero__title {
    margin-bottom: var(--space-sm);
  }

  .hero__lead {
    margin-bottom: var(--space-md);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: calc(var(--space-2xl) + var(--space-md)) var(--space-2xl);
    }
  }

  @media (max-width: 640px) {
    .hero__art {
      opacity: 0.3;
      right: -30%;
    }
  }
</style>
